// ============================================================
// RESTAURANT APP - Production Schema v5
// PostgreSQL (Supabase) - Multi-restaurant, audit, cash sessions
// onDelete: Cascade on all Restaurant child relations
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── RESTAURANT (Multi-tenant root) ────────────────────────
model Restaurant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  address            String   @default("")
  phone              String   @default("")
  active             Boolean  @default(true)
  subscriptionStatus String   @default("trial")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users             User[]
  products          Product[]
  tables            Table[]
  clients           Client[]
  orders            Order[]
  cashSessions      CashSession[]
  supplierPayments  SupplierPayment[]
  auditLogs         AuditLog[]

  @@index([subscriptionStatus])
}

// ─── USUARIOS ──────────────────────────────────────────────
model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  name               String   @default("")
  role               String   @default("camarero")
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  zone               String?
  restaurantId       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  ordersCreated      Order[]       @relation("OrderCreator")
  ordersReady        Order[]       @relation("OrderFinisher")
  payments           Payment[]
  auditLogs          AuditLog[]
  openedCashSessions CashSession[] @relation("CashSessionOpener")
  closedCashSessions CashSession[] @relation("CashSessionCloser")
  supplierPayments   SupplierPayment[]

  @@index([restaurantId])
  @@index([role])
  @@index([active])
}

// ─── PRODUCTOS ──────────────────────────────────────────────
model Product {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("")
  price        Float
  category     String   @default("general")
  stock        Int      @default(0)
  imageUrl     String   @default("")
  active       Boolean  @default(true)
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([restaurantId])
  @@index([category])
  @@index([active])
  @@unique([name, restaurantId])
}

// ─── MESAS ──────────────────────────────────────────────────
model Table {
  id           String  @id @default(cuid())
  number       Int
  capacity     Int     @default(4)
  status       String  @default("available")
  zone         String  @default("main")
  notes        String  @default("")
  active       Boolean @default(true)
  restaurantId String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([restaurantId])
  @@index([status])
  @@unique([number, restaurantId])
}

// ─── CLIENTES (CRM) ────────────────────────────────────────
model Client {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String   @default("")
  points       Int      @default(0)
  visits       Int      @default(0)
  notes        String   @default("")
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([restaurantId])
  @@unique([phone, restaurantId])
}

// ─── PEDIDOS ────────────────────────────────────────────────
model Order {
  id           String   @id @default(cuid())
  tableId      String
  clientId     String?
  status       String   @default("pending")
  subtotal     Float    @default(0)
  discount     Float    @default(0)
  total        Float    @default(0)
  notes        String   @default("")
  createdById  String?
  finishedById String?
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table       Table      @relation(fields: [tableId], references: [id], onDelete: Cascade)
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("OrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  finishedBy  User?      @relation("OrderFinisher", fields: [finishedById], references: [id], onDelete: SetNull)
  items       OrderItem[]
  payments    Payment[]

  @@index([restaurantId])
  @@index([status])
  @@index([tableId])
  @@index([clientId])
  @@index([createdAt])
}

// ─── ITEMS DE PEDIDO ────────────────────────────────────────
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int      @default(1)
  unitPrice   Float
  subtotal    Float
  notes       String   @default("")
  modifiers   String   @default("")
  status      String   @default("pending")
  destination String   @default("kitchen")
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([status])
  @@index([destination])
}

// ─── PAGOS (audit trail) ───────────────────────────────────
model Payment {
  id            String   @id @default(cuid())
  orderId       String
  userId        String?
  amount        Float
  method        String
  discount      Float    @default(0)
  freeDrinks    Int      @default(0)
  pointsUsed    Int      @default(0)
  pointsEarned  Int      @default(0)
  cashSessionId String?
  createdAt     DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([userId])
  @@index([cashSessionId])
  @@index([createdAt])
}

// ─── SESIÓN DE CAJA ────────────────────────────────────────
model CashSession {
  id              String    @id @default(cuid())
  restaurantId    String
  openedById      String?
  closedById      String?
  openingCash     Float     @default(0)
  closingCash     Float?
  expectedCash    Float?
  totalSales      Float     @default(0)
  totalCard       Float     @default(0)
  totalCash       Float     @default(0)
  totalSuppliers  Float     @default(0)
  closingCard     Float?
  cardDifference  Float?
  totalDifference Float?
  difference      Float?
  status          String    @default("open")
  openedAt        DateTime  @default(now())
  closedAt        DateTime?

  restaurant       Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  openedBy         User?             @relation("CashSessionOpener", fields: [openedById], references: [id], onDelete: SetNull)
  closedBy         User?             @relation("CashSessionCloser", fields: [closedById], references: [id], onDelete: SetNull)
  payments         Payment[]
  supplierPayments SupplierPayment[]

  @@index([restaurantId])
  @@index([status])
  @@index([openedAt])
}

// ─── LOG DE AUDITORÍA ──────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  restaurantId String
  userId       String?
  action       String
  entityType   String
  entityId     String?
  details      String   @default("")
  ipAddress    String   @default("")
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

// ─── PAGOS A PROVEEDORES ────────────────────────────────────
model SupplierPayment {
  id            String   @id @default(cuid())
  concept       String
  amount        Float
  userId        String?
  restaurantId  String
  cashSessionId String
  createdAt     DateTime @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  restaurant  Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([cashSessionId])
  @@index([userId])
  @@index([createdAt])
}