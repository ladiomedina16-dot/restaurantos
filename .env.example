# ═══════════════════════════════════════════════════════════════
# RestaurantOS — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# ⚠️  Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit .env or any file containing real secrets to Git.
# ⚠️  Generate secrets with: openssl rand -base64 48
# ═══════════════════════════════════════════════════════════════

# ─── Supabase PostgreSQL ─────────────────────────────────────
# DATABASE_URL: Pooler connection for runtime queries (pgbouncer)
#   REQUIRED for Vercel/serverless — uses Supabase pooler (port 6543)
#   Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# DIRECT_URL: Direct connection for Prisma migrations ONLY (port 5432)
#   Do NOT use for runtime queries — only for `prisma migrate deploy`
#   Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=

# ─── Supabase Client ────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── JWT Secrets ─────────────────────────────────────────────
# ⚠️  MUST be set to long random strings in production
# ⚠️  Generate each with: openssl rand -base64 48
# ⚠️  NEVER commit actual values to Git
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── API Secret ──────────────────────────────────────────────
# ⚠️  MUST be set to a long random string in production
API_SECRET=

# ─── Seed Passwords (only used during `bunx tsx prisma/seed.ts`) ──
# These are NOT used by the app at runtime.
# They are ONLY needed when running the database seed.
# The seed will ABORT if these are not set.
# ⚠️  Use strong passwords (12+ characters). They will be forced to change on first login.
SEED_SUPERADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_STAFF_PASSWORD=
