# ─── Supabase PostgreSQL ─────────────────────────────────────
# DATABASE_URL: Pooler connection for runtime queries (pgbouncer)
# Use your Supabase pooler URL (port 6543) — required for Vercel serverless
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# DIRECT_URL: Direct connection for Prisma migrations ONLY (port 5432)
# Do NOT use for runtime queries — only for `prisma migrate deploy`
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=

# ─── Supabase Client ────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── JWT Secrets ─────────────────────────────────────────────
# ⚠️ MUST be set to long random strings in production
# Generate each with: openssl rand -base64 48
# NEVER commit actual values to Git
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── API Secret ──────────────────────────────────────────────
# ⚠️ MUST be set to a long random string in production
API_SECRET=
