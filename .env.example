# ─── Supabase PostgreSQL ─────────────────────────────────────
# Pooler URL for runtime queries (PgBouncer)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for Prisma migrations only
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Authentication ─────────────────────────────────────────
# JWT secret for access tokens (generate with: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here"
# JWT secret for refresh tokens (generate with: openssl rand -base64 32)
JWT_REFRESH_SECRET="your-refresh-secret-here"
# API secret for internal service communication
API_SECRET="your-api-secret-here"

# ─── Supabase (optional, for future Realtime) ───────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
